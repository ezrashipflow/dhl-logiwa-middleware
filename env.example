# ──────────────────────────────────────────────────
# DHL eCommerce Americas API Credentials
# Get these from your DHL account / DHL Developer Portal
# ──────────────────────────────────────────────────

# Your DHL API Client ID (also called "API Key")
DHL_CLIENT_ID=your_dhl_client_id_here

# Your DHL API Client Secret
DHL_CLIENT_SECRET=your_dhl_client_secret_here

# Your DHL Pickup Account Number (5-7 digit number DHL gave you)
DHL_PICKUP_ID=your_dhl_pickup_number_here

# Your DHL Distribution Center code (e.g. USDFW1, USCLT1, USLAX1)
# Ask DHL which distribution center serves your warehouse location
DHL_DISTRIBUTION=USDFW1

# ──────────────────────────────────────────────────
# Server Config
# ──────────────────────────────────────────────────

# Railway sets this automatically — don't change it
PORT=3000
